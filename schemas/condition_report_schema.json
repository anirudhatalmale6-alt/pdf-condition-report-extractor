{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Australian Residential Tenancy Condition Report",
  "type": "object",
  "required": ["jurisdiction", "document_type", "report_metadata", "areas"],
  "properties": {
    "jurisdiction": { "type": "string", "enum": ["NSW", "VIC", "QLD", "SA", "WA", "TAS", "ACT", "NT"] },
    "document_type": { "type": "string", "enum": ["move_in", "move_out", "combined"] },
    "detected_document_type": { "type": ["string", "null"] },
    "report_metadata": {
      "type": "object",
      "properties": {
        "address": { "type": ["string", "null"] },
        "postcode": { "type": ["string", "null"] },
        "report_number": { "type": ["string", "null"] },
        "tenant_name": { "type": ["string", "null"] },
        "landlord_name": { "type": ["string", "null"] },
        "property_manager": { "type": ["string", "null"] },
        "bond_number": { "type": ["string", "null"] },
        "date_received": { "type": ["string", "null"] },
        "start_date": { "type": ["string", "null"] },
        "end_date": { "type": ["string", "null"] },
        "source_file": { "type": "string" },
        "total_pages": { "type": "integer" },
        "extraction_timestamp": { "type": "string", "format": "date-time" },
        "extractor_version": { "type": "string" }
      }
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["area_name", "components"],
        "properties": {
          "area_name": { "type": "string" },
          "page_number": { "type": ["integer", "null"] },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["component_name"],
              "properties": {
                "component_name": { "type": "string" },
                "start_of_tenancy": {
                  "type": "object",
                  "properties": {
                    "clean": { "type": ["string", "null"] },
                    "undamaged": { "type": ["string", "null"] },
                    "working": { "type": ["string", "null"] },
                    "landlord_comments": { "type": ["string", "null"] },
                    "tenant_agrees": { "type": ["string", "null"] },
                    "tenant_comments": { "type": ["string", "null"] }
                  }
                },
                "end_of_tenancy": {
                  "type": "object",
                  "properties": {
                    "clean": { "type": ["string", "null"] },
                    "undamaged": { "type": ["string", "null"] },
                    "working": { "type": ["string", "null"] },
                    "comments": { "type": ["string", "null"] },
                    "tenant_agrees": { "type": ["string", "null"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "other_sections": {
      "type": "object",
      "properties": {
        "compliance": { "type": "object" },
        "utilities": { "type": "object" },
        "water_efficiency": { "type": "object" },
        "smoke_alarms": { "type": "object" },
        "safety_issues": { "type": "object" },
        "additional_comments": { "type": ["string", "null"] },
        "maintenance_dates": { "type": "object" },
        "landlord_promise": { "type": ["string", "null"] },
        "signatures": { "type": "object" }
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "index": { "type": "integer" },
          "width": { "type": "integer" },
          "height": { "type": "integer" },
          "format": { "type": "string" },
          "data_base64": { "type": ["string", "null"] },
          "file_path": { "type": ["string", "null"] }
        }
      }
    }
  }
}
